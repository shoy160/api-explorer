# API Explorer 配置文件
# 将此文件复制为 .env 并根据需要修改配置

# OpenAPI 文档配置
# 支持带分组名称的配置格式
# 格式: [{"name": "分组名称", "path": "OpenAPI文档地址"}, ...]
# 示例:
# VITE_OPENAPI_CONFIG='[{"name": "认证端 API", "path": "https://api.example.com/openapi/auth"}, {"name": "管理端 API", "path": "https://api.example.com/openapi/manage"}]'
VITE_OPENAPI_CONFIG='[{"name": "认证端 API", "path": "http://localhost:8010/v3/api-docs/auth-api"}, {"name": "管理端 API", "path": "http://localhost:8010/v3/api-docs/manage-api"}]'

# 应用标题
VITE_APP_TITLE=API Explorer

# 应用描述
VITE_APP_DESCRIPTION=API 文档中心
